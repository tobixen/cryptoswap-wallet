#!/usr/bin/env bash
# Pre-push release gate.
#
# When pushing an annotated release tag (refs/tags/v*), run lint + the full test
# suite INCLUDING the live THORChain integration tests (`-m network`), and block
# the push if anything fails. Non-release pushes are unaffected.
#
# Bypass (not recommended): git push --no-verify
#
# Activate once per clone:  git config core.hooksPath .githooks
set -uo pipefail

releasing=false
while read -r _local_ref _local_sha remote_ref _remote_sha; do
    case "$remote_ref" in
        refs/tags/v*) releasing=true ;;
    esac
done

[ "$releasing" = true ] || exit 0

echo "pre-push: release tag detected — running pre-release checks..."
run() {
    echo "+ $*"
    "$@" || { echo "pre-release check FAILED: $*" >&2; exit 1; }
}
run uv run ruff check .
run uv run pytest
run uv run pytest -m network
echo "pre-push: all pre-release checks passed."
